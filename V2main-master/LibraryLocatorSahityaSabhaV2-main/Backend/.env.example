PORT=3000
NODE_ENV=production

JWT_SECRET=replace-with-strong-random-secret

EMAIL_USER=your-smtp-email@example.com
EMAIL_PASS=your-smtp-app-password

DB_HOST=your-mysql-host
DB_USER=your-mysql-user
DB_PASS=your-mysql-password
DB_NAME=your-mysql-database
DB_POOL_LIMIT=10

# Optional frontend and CORS values for cloud deployments
FRONTEND_URL=https://your-frontend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example,https://your-second-domain.example
